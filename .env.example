# ============================================================
# WebSentinel - Environment Configuration
# ============================================================
# Set your preferred LLM provider and API keys below.
# Only ONE provider needs to be configured.
#
# PROVIDER PRIORITY (when LLM_PROVIDER=auto or unset):
#   1. Google Gemini  (if GOOGLE_API_KEY is set)
#   2. OpenAI         (if OPENAI_API_KEY is set)
#   3. Anthropic      (if ANTHROPIC_API_KEY is set)
#   4. Ollama         (always available, runs locally)
# ============================================================

# --- LLM Provider Selection ---
# Options: auto | google | openai | anthropic | ollama
LLM_PROVIDER=google

# --- Google Vertex AI (via Service Account) ---
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_MODEL=gemini-2.5-flash

# Skip browser-use API key check (Vertex AI uses service account, not env key)
SKIP_LLM_API_KEY_VERIFICATION=true

# --- OpenAI ---
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ANTHROPIC_MODEL=

# --- Ollama (Local - No API Key Required) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:0.8b

# --- Browser & Encoding ---
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
